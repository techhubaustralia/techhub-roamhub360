# RoamHub360 — self-hosted config. Copy to .env and fill in. NEVER commit .env.

# ---- Database (Postgres) ----
# POSTGRES_PASSWORD is used by the 'db' service; it MUST match the password in DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-a-strong-password
# App -> DB. Host 'db' is the compose service name; user/db match the 'db' service.
DATABASE_URL=postgresql://roamhub:change-me-to-a-strong-password@db:5432/roamhub360?schema=public

# ---- Public address ----
# A real hostname => Caddy gets a free Let's Encrypt cert automatically.
# Use ":80" for a plain local/IP test without TLS.
SITE_ADDRESS=demo.roamhub360.com
APP_URL=https://demo.roamhub360.com

# ---- Secrets (required) ----
# The app REFUSES TO BOOT in production without CHECKIN_SECRET.
# Generate each with:  openssl rand -hex 32
CHECKIN_SECRET=
JOBS_SECRET=

# Break-glass admin(s), comma-separated. Until the multi-tenant auth step lands, this is
# how you designate admins. WARNING: off Azure there is no login yet — keep the demo private.
BOOTSTRAP_ADMINS=you@yourdomain.com

# ---- Auth (Auth.js) ----
# Session signing secret (required). Generate:  openssl rand -base64 32
AUTH_SECRET=
# Microsoft Entra SSO — OPTIONAL. Leave blank for local email/password only (orgs
# without Microsoft). Multi-tenant by default (any Microsoft org can sign in).
# Register this redirect URI on the Entra app:
#   https://<your-domain>/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
# Google SSO — OPTIONAL. Leave blank to disable. Register this redirect URI:
#   https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Microsoft Graph (optional: email + Outlook calendar). Leave blank to disable. ----
AZURE_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_FROM=
GRAPH_TIMEZONE=AUS Eastern Standard Time
# JSON map of room spaceKey -> resource mailbox, e.g. {"room-boardroom":"boardroom@yourco.com"}
ROOM_MAILBOXES=
