# RoamHub360 — self-hosted config. Copy to .env and fill in. NEVER commit .env.

# ---- Database (Postgres) ----
# POSTGRES_PASSWORD is used by the 'db' service; it MUST match the password in DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-a-strong-password
# App -> DB. Host 'db' is the compose service name; user/db match the 'db' service.
DATABASE_URL=postgresql://roamhub:change-me-to-a-strong-password@db:5432/roamhub360?schema=public

# ---- Public address ----
# A real hostname => Caddy gets a free Let's Encrypt cert automatically.
# Use ":80" for a plain local/IP test without TLS.
SITE_ADDRESS=app.roamhub360.com
APP_URL=https://app.roamhub360.com

# ---- Secrets (required) ----
# The app REFUSES TO BOOT in production without CHECKIN_SECRET.
# Generate each with:  openssl rand -hex 32
CHECKIN_SECRET=
JOBS_SECRET=

# Break-glass admin(s), comma-separated. Until the multi-tenant auth step lands, this is
# how you designate admins. WARNING: off Azure there is no login yet — keep the demo private.
BOOTSTRAP_ADMINS=you@yourdomain.com

# ---- Auth (Auth.js) ----
# Session signing secret (required). Generate:  openssl rand -base64 32
AUTH_SECRET=
# Microsoft Entra SSO — OPTIONAL. Leave blank for local email/password only (orgs
# without Microsoft). Multi-tenant by default (any Microsoft org can sign in).
# Register this redirect URI on the Entra app:
#   https://<your-domain>/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0
# Microsoft Teams SSO — OPTIONAL. Only needed if the Teams tab audience is NOT the default
# `api://<APP_URL host>/<client id>` (auto-derived from APP_URL). Set it to the Entra app's
# Application ID URI to match teams/manifest.json webApplicationInfo.resource exactly.
TEAMS_SSO_AUDIENCE=
# Google SSO — OPTIONAL. Leave blank to disable. Register this redirect URI:
#   https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Commercial SaaS operations (CP4). OPS_EMAIL receives licence-expiry alerts (falls back to
# BOOTSTRAP_ADMINS). BILLING_PROVIDER is a forward-looking seam (stripe|marketplace|xero|myob) —
# unimplemented today; leave as "none". ----
OPS_EMAIL=
BILLING_PROVIDER=none

# ---- AI booking concierge (optional). Powers the in-app "Ask" assistant that finds and books
# spaces in natural language. Leave all blank to hide it. Two ways to provide a model:
#
# 1) Anthropic (paid): set ANTHROPIC_API_KEY (+ optional ASSISTANT_MODEL, default claude-opus-4-8).
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-opus-4-8
#
# 2) Any OpenAI-compatible endpoint — including FREE tiers (Google Gemini, Groq, Mistral,
#    OpenRouter, Cerebras). Set AI_API_KEY + AI_BASE_URL + AI_MODEL. If both are set, AI_* wins
#    (override with AI_PROVIDER=anthropic). Recipes:
#      Gemini (free key from aistudio.google.com):
#        AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#        AI_MODEL=gemini-2.5-flash
#      Groq (free, very fast; console.groq.com):
#        AI_BASE_URL=https://api.groq.com/openai/v1
#        AI_MODEL=llama-3.3-70b-versatile
#    NOTE: free tiers have rate limits and MAY train on data — fine for demos/internal use, but for
#    strict customer-data isolation use a paid/no-retention tier. Choose per deployment.
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ---- Web push notifications (optional). When set, staff can enable device push in Settings and get
# instant booking-confirmed/updated/cancelled alerts (no email needed). Leave blank to disable —
# email still works. Generate the key pair ONCE and keep it stable:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@techhubaustralia.com.au

# ---- Transactional email via Resend (recommended for reliable delivery). When set, ALL app email
# (password reset, invites, booking confirmations, digests) sends through Resend instead of each
# customer's Microsoft 365. Verify your domain in Resend, then set a verified sender.
RESEND_API_KEY=
RESEND_FROM=RoamHub360 <noreply@roamhub360.com>

# ---- Stripe billing (optional). Set BILLING_PROVIDER=stripe to enable live checkout + webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Self-serve trial signup (G5). OFF by default — set to "true" to let prospects create their own
# workspace + 14-day trial at /signup (public tenant creation; keep off unless you want PLG).
ALLOW_PUBLIC_SIGNUP=false

# ---- Secret encryption (Commercial SaaS CP1). REQUIRED to let customers save their own Microsoft
# credentials (encrypted at rest, AES-256-GCM). Generate once: openssl rand -base64 32
# Rotating this makes previously-saved customer secrets unreadable (they must be re-entered).
CREDENTIAL_KEY=

# ---- Microsoft Graph (optional: email + Outlook calendar + directory sync). Leave blank to disable. ----
# These GRAPH_* vars are the DEFAULT/demo tenant's app. Customer tenants configure their own under
# Settings → Microsoft integration (stored encrypted per tenant), and don't use these.
# App-only permissions to grant + admin-consent: Mail.Send, Calendars.ReadWrite (email/calendar),
# and User.Read.All (Team Build-Up B: "Who's in" directory sync — names, photos, departments).
AZURE_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_FROM=
GRAPH_TIMEZONE=AUS Eastern Standard Time
# JSON map of room spaceKey -> resource mailbox, e.g. {"room-boardroom":"boardroom@yourco.com"}
ROOM_MAILBOXES=
