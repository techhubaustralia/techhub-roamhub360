// Azure SQL Database — bookings, check-ins, locks, audit.
// Buildings + floor-plan geometry live in code / Azure Blob, not SQL.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A customer organisation (tenant) — the isolation boundary for all data. Resolved
// from the request subdomain (<slug>.roamhub360.com); app./www./localhost => "default".
model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  status    String   @default("active") // active | trial | suspended
  features  String[] @default([]) // DISABLED feature keys (CP3 feature flags), e.g. "presence"
  createdAt DateTime @default(now())
}

model Booking {
  id            String    @id @default(uuid())
  tenantId      String    @default("default")
  userEmail     String
  bookedByEmail String? // set when an admin books on behalf
  buildingId    String
  spaceKey      String
  spaceLabel    String
  kind          String // desk | office | room
  durationType  String // hourly | half | full
  start         String // ISO-local "YYYY-MM-DDTHH:mm"
  end           String
  status        String    @default("Booked") // Booked | Checked in | Cancelled | Declined
  eventId       String? // Graph room-mailbox calendar event id (room bookings); null until/unless reserved
  cancelledBy   String? // email of whoever cancelled; differs from owner => admin cancellation
  cancelReason  String? // optional reason supplied at cancellation
  createdAt     DateTime  @default(now())
  checkIns      CheckIn[]

  @@index([buildingId, spaceKey])
  @@index([userEmail])
  @@index([tenantId])
}

model CheckIn {
  id           String   @id @default(uuid())
  tenantId     String   @default("default")
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  date         String // ISO date for that day (multi-day desks check in daily)
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  @@unique([bookingId, date])
}

model Lock {
  tenantId   String   @default("default")
  buildingId String
  spaceKey   String
  scope      String   @default("temporary") // temporary | permanent
  lockedBy   String?
  createdAt  DateTime @default(now())

  @@id([tenantId, buildingId, spaceKey])
}

model AuditLog {
  id       String   @id @default(uuid())
  tenantId String   @default("default")
  at       DateTime @default(now())
  actor    String
  action   String
  detail   String?

  @@index([tenantId])
}

// Per-tenant licence (Commercial SaaS CP2). Sites are the billing unit ($2000/site/yr); the
// tier caps floors-per-site (≤5). Issued/edited by the TechHub Partner portal (CP3). Absence of
// a row = an implicit trial; the DEFAULT/demo tenant is always treated as unlimited/active.
model License {
  tenantId         String    @id
  tier             String    @default("trial") // trial | standard | professional | enterprise
  maxSites         Int       @default(1)
  maxFloorsPerSite Int       @default(2)
  status           String    @default("active") // active | suspended | cancelled
  startsAt         DateTime?
  expiresAt        DateTime?
  graceDays        Int       @default(14)
  notes            String?
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
}

// Per-customer Microsoft integration (Commercial SaaS CP1). Each tenant configures THEIR OWN
// Entra app (Azure tenant + client id + secret) so directory/mail/calendar run against the
// customer's Microsoft 365. The client secret is encrypted at rest (AES-256-GCM, lib/crypto)
// and NEVER returned to the browser. One row per tenant.
model TenantIntegration {
  tenantId      String   @id
  azureTenantId String? // the customer's Entra tenant (directory) id
  graphClientId String? // their app registration's client id
  secretEnc     String? // AES-256-GCM ciphertext of the client secret (iv.tag.ct); never exposed
  lastTestOk    Boolean? // result of the last connection test
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// A cached snapshot of the customer's Microsoft Entra directory (Team Build-Up B).
// Populated by syncDirectory() from Graph /users; joined to bookings by email to show
// real names, titles, departments, managers and photos in "Who's in". Per-tenant.
model DirectoryUser {
  id             String   @id @default(uuid())
  tenantId       String   @default("default")
  email          String // mail or userPrincipalName, lowercased — join key to Booking.userEmail
  displayName    String?
  givenName      String?
  surname        String?
  jobTitle       String?
  department     String?
  officeLocation String?
  managerEmail   String?
  photo          String? // 48px thumbnail as a data: URL, or null when the user has no photo
  syncedAt       DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

// App users. Source of truth for identity + role, whether they sign in with
// Microsoft Entra (SSO) or a local email/password (for orgs without Microsoft).
// passwordHash is null for SSO-only users. Roles/sites move here off the old
// _roles.json + Entra-group mapping (which required Azure Easy Auth).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String? // bcrypt; null for SSO-only (Entra) users
  role         String   @default("staff") // global-admin | site-admin | staff
  sites        String[] @default([]) // building roots a site-admin may manage
  multiBook    Boolean  @default(false) // "Office Manager": multiple desks/day
  provider     String   @default("credentials") // credentials | entra
  tenantId     String? // per-customer isolation (completed in the multi-tenant phase)
  hidePresence Boolean  @default(false) // Team Build-Up C: opt out of the "Who's in" board
  notifyPresence Boolean @default(false) // Team Build-Up D: receive the daily "who's in" digest
  createdAt    DateTime @default(now())

  @@index([tenantId])
}
